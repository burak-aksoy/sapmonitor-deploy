# =============================================================================
# SAP Monitoring Platform — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sapmon:sapmon@postgres:5432/sapmon
REDIS_URL=redis://redis:6379/0

# --- SAP Connection (single system) ---
# Leave as placeholder if SAP is not yet configured — collectors will skip polling
SAP_BASE_URL=https://your-s4-tenant.s4hana.ondemand.com
SAP_AUTH_TYPE=oauth2                        # oauth2 | basic
SAP_CLIENT_ID=your-oauth-client-id
SAP_CLIENT_SECRET=your-oauth-client-secret
SAP_TOKEN_URL=https://your-btp-tenant.authentication.eu10.hana.ondemand.com/oauth/token
# Basic auth only (leave empty if using oauth2)
SAP_USERNAME=
SAP_PASSWORD=

# --- LLM Provider ---
LLM_PROVIDER=openai                         # openai | claude | gemini | ollama
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Optional fallback provider if primary fails
LLM_FALLBACK_PROVIDER=
# LLM response cache — reuses Redis; avoids duplicate LLM calls for same error type
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=86400          # 24 hours
# Claude (fallback or primary)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Gemini (fallback or primary)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Notifications: Email (SMTP) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sapmonitoring@yourcompany.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=SAP Monitoring <sapmonitoring@yourcompany.com>

# --- Initial Admin User (created automatically on first startup) ---
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=changeme

# --- Authentication (JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-a-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# --- Encryption (for DB-stored secrets like Teams webhook URLs) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# --- Polling Intervals (seconds) ---
POLL_INTERVAL_JOBS_SECONDS=300
POLL_INTERVAL_IDOCS_SECONDS=300
IDOC_LOOKBACK_DAYS=2
POLL_INTERVAL_INTEGRATIONS_SECONDS=120
# IDoc report email (sent once per day to all active teams with an email address)
IDOC_DIGEST_ENABLED=true
IDOC_DIGEST_TIME=07:00          # HH:MM, 24h UTC
IDOC_DIGEST_LOOKBACK_HOURS=24

# IDoc status codes treated as errors (comma-separated). Default: 51,56,63,64,65
# 51=not posted, 56=errors added, 63=error passing to app, 64=ready to transfer, 65=ALE error
# 52=application document posted (SUCCESS) — do NOT add here
IDOC_ERROR_STATUSES=51,56,63,64,65

# --- Data Retention ---
# Number of days to keep old records (set to 0 to keep forever)
RETENTION_ALERTS_DAYS=90            # resolved/suppressed alerts + their LLM analyses and dispatch records
RETENTION_HEALTH_SNAPSHOTS_DAYS=30  # integration health check history
RETENTION_BACKGROUND_JOBS_DAYS=30   # background job rows
RETENTION_IDOC_RECORDS_DAYS=30      # IDoc record rows
# Fire cleanup jobs at beat startup if last successful run is older than this many days
CLEANUP_STARTUP_STALE_DAYS=3

# --- App ---
APP_ENV=development                         # development | production
LOG_LEVEL=INFO
# Set to false during development to suppress all Teams + email notifications
NOTIFICATIONS_ENABLED=true
